{
  "entries": ["assembly/codec/index.ts"],
  "targets": {
    "debug": {
      "outFile": "build/codec.debug.wasm",
      "textFile": "build/codec.debug.wat",
      "sourceMap": true,
      "debug": true,
      "exportRuntime": true
    },
    "release": {
      "outFile": "build/codec.wasm",
      "textFile": "build/codec.wat",
      "optimizeLevel": 3,
      "shrinkLevel": 2,
      "converge": false,
      "noAssert": true,
      "exportRuntime": true
    }
  },
  "options": {
    "bindings": "raw",
    "enable": ["simd"]
  }
}
